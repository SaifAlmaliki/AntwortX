# Canonical site URL (no trailing slash) — used for sitemap, robots, and metadata
NEXT_PUBLIC_SITE_URL=https://zempar.com

# GEO report pipeline — SMTP used after the PDF is built (same request as POST /api/geo-lead)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=you@example.com
# SMTP_PASS=your-app-password-or-secret
# GEO_LEAD_NOTIFY_TO=contact@zempar.com
# GEO_LEAD_FROM="Zempar <contact@zempar.com>"
#
# Local dev: many networks block outbound SMTP (587). Skip mail but still run the GEO pipeline:
# GEO_LEAD_SKIP_EMAIL=true
# SMTP_CONNECTION_TIMEOUT_MS=15000
